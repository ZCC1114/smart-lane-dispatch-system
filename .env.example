APP_HTTP_PORT=3002
APP_PUBLIC_HOST=192.168.124.3
APP_CORS_ALLOWED_ORIGINS=http://192.168.124.3:3002,http://localhost:3002,http://127.0.0.1:3002,http://localhost:3000,http://127.0.0.1:3000
APP_JWT_SECRET=replace-with-a-long-random-secret
APP_JWT_EXPIRE_HOURS=8

MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=smart_lane_dispatch
MYSQL_USER=smartlane
MYSQL_PASSWORD=smartlane

REDIS_PORT=6379

MQTT_PORT=1883
MQTT_WS_PORT=9001

APP_BOOTSTRAP_ADMIN_ENABLED=false
APP_BOOTSTRAP_ADMIN_USERNAME=
APP_BOOTSTRAP_ADMIN_PASSWORD=
APP_BOOTSTRAP_ADMIN_DISPLAY_NAME=系统超级管理员
APP_BOOTSTRAP_ADMIN_STATION=总控中心

# 现场联调默认启用 MQTT 网关。
# 如果只是本地演示、不接现场设备，可改回:
# APP_DEVICE_GATEWAY=mock
# APP_DEVICE_MQTT_ENABLED=false
APP_DEVICE_GATEWAY=mqtt
APP_DEVICE_MQTT_ENABLED=true
APP_DEVICE_MQTT_HOST=mqtt
APP_DEVICE_MQTT_PORT=1883
APP_DEVICE_MQTT_CLIENT_ID=smart-lane-dispatch-system
APP_DEVICE_MQTT_USERNAME=
APP_DEVICE_MQTT_PASSWORD=

# 总入口 MF 车牌识别摄像头，报文 Topic 为 /{sn}/mf/up。
# 示例: SN=00E02721A3A7, deviceNo=22K5000202407828。
# 至少填写 SN；如果同一 SN 下有多路相机，再同时填写 groupId/deviceNo。
APP_DEVICE_PARKING_MF_YARD_ENTRY_SN=
APP_DEVICE_PARKING_MF_YARD_ENTRY_GROUP_ID=
APP_DEVICE_PARKING_MF_YARD_ENTRY_DEVICE_NO=

# 计数报警协议的总入口/共享入口相机 devId。使用 MF 协议时保持为空。
APP_DEVICE_SMART_CAMERA_YARD_ENTRY_CAMERA_DEV_ID=
APP_DEVICE_SMART_CAMERA_ACTIVE_ENTRY_CAMERA_DEV_ID=

APP_DEVICE_DIDO_PAYLOAD_MODE=hex-a1
APP_DEVICE_DIDO_RELAY_MODE=ordinary
APP_DEVICE_DIDO_ENABLE_REMOTE_CONFIG_ON_CONNECT=false
APP_DEVICE_DIDO_ENABLE_RELAY_UPLOAD_ON_CONNECT=false

# 共用 CX/DIDO 继电器设备。若现场每条车道独立设备，可覆盖 APP_DEVICE_Lxx_DIDO_DEVICE_ID。
APP_DEVICE_SHARED_ENTRY_DIDO_DEVICE_ID=DIDO-01
APP_DEVICE_SHARED_ENTRY_DIDO_HOST=192.168.1.18
APP_DEVICE_SHARED_ENTRY_DIDO_PORT=8080

# 11 条车道入口 Smart Camera 和地感配置。
# 现场只需要把每条车道的 Lxx_CAMERA_DEV_ID 改成实际 Smart Camera 设备码。
# 默认接线: A01-A11 为入口绿灯继电器，B01-B11 为出口地感输入。
APP_DEVICE_L01_CAMERA_DEV_ID=
APP_DEVICE_L01_ENTRY_GREEN_RELAY=A01
APP_DEVICE_L01_EXIT_TRIGGER_INPUT_KEY=B01

APP_DEVICE_L02_CAMERA_DEV_ID=
APP_DEVICE_L02_ENTRY_GREEN_RELAY=A02
APP_DEVICE_L02_EXIT_TRIGGER_INPUT_KEY=B02

APP_DEVICE_L03_CAMERA_DEV_ID=
APP_DEVICE_L03_ENTRY_GREEN_RELAY=A03
APP_DEVICE_L03_EXIT_TRIGGER_INPUT_KEY=B03

APP_DEVICE_L04_CAMERA_DEV_ID=
APP_DEVICE_L04_ENTRY_GREEN_RELAY=A04
APP_DEVICE_L04_EXIT_TRIGGER_INPUT_KEY=B04

APP_DEVICE_L05_CAMERA_DEV_ID=
APP_DEVICE_L05_ENTRY_GREEN_RELAY=A05
APP_DEVICE_L05_EXIT_TRIGGER_INPUT_KEY=B05

APP_DEVICE_L06_CAMERA_DEV_ID=
APP_DEVICE_L06_ENTRY_GREEN_RELAY=A06
APP_DEVICE_L06_EXIT_TRIGGER_INPUT_KEY=B06

APP_DEVICE_L07_CAMERA_DEV_ID=
APP_DEVICE_L07_ENTRY_GREEN_RELAY=A07
APP_DEVICE_L07_EXIT_TRIGGER_INPUT_KEY=B07

APP_DEVICE_L08_CAMERA_DEV_ID=
APP_DEVICE_L08_ENTRY_GREEN_RELAY=A08
APP_DEVICE_L08_EXIT_TRIGGER_INPUT_KEY=B08

APP_DEVICE_L09_CAMERA_DEV_ID=
APP_DEVICE_L09_ENTRY_GREEN_RELAY=A09
APP_DEVICE_L09_EXIT_TRIGGER_INPUT_KEY=B09

APP_DEVICE_L10_CAMERA_DEV_ID=
APP_DEVICE_L10_ENTRY_GREEN_RELAY=A10
APP_DEVICE_L10_EXIT_TRIGGER_INPUT_KEY=B10

APP_DEVICE_L11_CAMERA_DEV_ID=
APP_DEVICE_L11_ENTRY_GREEN_RELAY=A11
APP_DEVICE_L11_EXIT_TRIGGER_INPUT_KEY=B11

CX6E_TCP_BRIDGE_ENABLED=true
CX6E_TCP_BRIDGE_DEVICE_ID=DIDO-01
CX6E_TCP_BRIDGE_HOST=192.168.1.18
CX6E_TCP_BRIDGE_PORT=8080
CX6E_TCP_BRIDGE_PROTOCOL=A1
