ARG DOCKER_IMAGE_REGISTRY=docker.m.daocloud.io/library

FROM ${DOCKER_IMAGE_REGISTRY}/node:22-slim AS deps
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

FROM ${DOCKER_IMAGE_REGISTRY}/node:22-slim AS build
WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL=/api
ARG NEXT_PUBLIC_WS_ENDPOINT=/ws
ARG NEXT_PUBLIC_DEVICE_MQTT_HOST=127.0.0.1
ARG NEXT_PUBLIC_MQTT_WS_HOST=127.0.0.1
ARG NEXT_PUBLIC_MQTT_USERNAME=jcadmin
ARG NEXT_PUBLIC_MQTT_PASSWORD=jcadmin@12345

ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
ENV NEXT_PUBLIC_WS_ENDPOINT=${NEXT_PUBLIC_WS_ENDPOINT}
ENV NEXT_PUBLIC_DEVICE_MQTT_HOST=${NEXT_PUBLIC_DEVICE_MQTT_HOST}
ENV NEXT_PUBLIC_MQTT_WS_HOST=${NEXT_PUBLIC_MQTT_WS_HOST}
ENV NEXT_PUBLIC_MQTT_USERNAME=${NEXT_PUBLIC_MQTT_USERNAME}
ENV NEXT_PUBLIC_MQTT_PASSWORD=${NEXT_PUBLIC_MQTT_PASSWORD}
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN npm run build -- --webpack

FROM ${DOCKER_IMAGE_REGISTRY}/node:22-slim AS runtime
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000

COPY --from=build /app/public ./public
COPY --from=build /app/.next/standalone ./
COPY --from=build /app/.next/static ./.next/static

EXPOSE 3000

CMD ["node", "server.js"]
